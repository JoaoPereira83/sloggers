# Admin credentials for the gallery editor and member approvals at /admin
ADMIN_PASSWORD=sloggers

# Password for starting/ending live rides — only used by automated nightly cleanup now
RIDE_ADMIN_PASSWORD=sloggers

# Used to encrypt session cookies — change this in production
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Supabase — required on Vercel for the live ride tracker (/ride)
# Create a free project at https://supabase.com, run supabase/schema.sql, then paste keys here.
# Must be the Project URL from Supabase → Settings → General (NOT the supabase.com/dashboard link)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Join form at /join and member approval emails — free via https://formsubmit.co
# Optional: set in Vercel (either name works). Default is in src/config/site.ts
# VITE_FORMSUBMIT_EMAIL=your-club-email@example.com
# FORMSUBMIT_EMAIL=your-club-email@example.com

# Optional: reliable server-side approval emails via https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Southam Sloggers <hello@yourdomain.com>

# Optional: public site URL used in approval emails (defaults to VERCEL_URL or sloggers.vercel.app)
# SITE_URL=https://sloggers.vercel.app

# Optional: protect the nightly ride-expiry cron endpoint
# CRON_SECRET=your-random-secret
